# ClawMe Skill Maker — API Keys 配置示例
# 复制此文件为 secrets.toml 并填入真实 Key：
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# 也可在侧边栏「配置 API Keys」中直接输入，输入后自动保存到本次会话。

# DeepSeek Chat，推荐优先试用，deepseek.com 免费注册
DEEPSEEK_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# Kimi (Moonshot)，platform.moonshot.cn
MOONSHOT_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# 通义千问 Max，dashscope.aliyuncs.com（阿里云）
DASHSCOPE_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# MiniMax M2.1，platform.minimax.io
MINIMAX_API_KEY = "xxxxxxxxxxxxxxxxxxxxxxxx"

# Claude 3.5 Sonnet，console.anthropic.com
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"
